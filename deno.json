{
  "name": "quiz-multiplayer-game",
  "version": "1.0.0",
  "exports": "./main.ts",
  "tasks": {
    "dev": "deno run --watch --allow-net --allow-read --allow-write --allow-env --unstable-kv main.ts",
    "start": "deno run --allow-net --allow-read --allow-write --allow-env --unstable-kv main.ts"
  },
  "imports": {
    "@std/http": "jsr:@std/http@^1.1.0",
    "@std/path": "jsr:@std/path@^1.1.4",
    "@std/uuid": "jsr:@std/uuid@^1.1.1",
    "vue": "https://unpkg.com/vue@3.5.33/dist/vue.esm-browser.js"
  },
  "compilerOptions": {
    "strict": true
  },
  "deploy": {
    "project": "quiz-game",
    "exclude": ["**/node_modules"],
    "include": [],
    "entrypoint": "main.ts"
  }
}